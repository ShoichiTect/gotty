{
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "outDir": "./dist/",
    "declaration": true,
    "sourceMap": true,
    "target": "es2018",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "baseUrl": ".",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules"
  ]
}
